      "id": "8fe23178-7747-4b71-992a-4e02612cfb7d",
      "name": "Descargar Imagen Kommo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [ 208, 1200 ]
    },
    {
      "parameters": {
        "jsCode": "const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst message_id = $('Normalizar Datos').item.json.message_id;\n\n// IMPORTANTE: Pega aquí tu clave secreta de Supabase (service_role)\nconst SUPABASE_KEY = \"PEGA_TU_CLAVE_SERVICE_ROLE_AQUI\";\n\nconst URL = `https://rcqkmaxkuxllcyjzqbvn.supabase.co/storage/v1/object/documentos_operacionales/kommo_${message_id}.jpg`;\n\ntry {\n  const response = await this.helpers.httpRequest({\n    method: 'POST',\n    url: URL,\n    headers: {\n      'Authorization': `Bearer ${SUPABASE_KEY}`,\n      'Content-Type': 'image/jpeg',\n      'x-upsert': 'true'\n    },\n    body: buffer,\n    encoding: null\n  });\n  return { json: { success: true, response } };\n} catch (error) {\n  throw new Error(`Error de Supabase: ${JSON.stringify(error.response?.data || error.message)}`);\n}"
      },
