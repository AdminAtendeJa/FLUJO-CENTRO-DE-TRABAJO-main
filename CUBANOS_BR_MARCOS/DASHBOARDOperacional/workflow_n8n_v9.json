      "id": "ce49dc2d-90cd-41f6-8d34-8e6190f630f3",
      "name": "Webhook (Recibe de Kommo)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ -880, 1408 ],
      "webhookId": "generado-automaticamente"
