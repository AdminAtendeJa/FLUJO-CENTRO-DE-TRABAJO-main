{
  "manifest_version": 3,
  "name": "Cubanos BR Auto-Fill",
  "version": "1.0",
  "description": "Extensión para autocompletar formularios de trámites con datos desde Supabase.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
