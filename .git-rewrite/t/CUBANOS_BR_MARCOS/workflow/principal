        "jsCode": "const contactoRaw = $input.first().json.data;\nconst contacto = typeof contactoRaw === 'string' ? JSON.parse(contactoRaw) : contactoRaw;\n\nconst leadNode = $('Extraer contactoId').item.json;\nconst lead = leadNode.leadData || {};\n\nconst camposContacto = contacto.custom_fields_values || [];\nconst camposLead = lead.custom_fields_values || [];\n\nconst getField = (campos, nombre) => {\n  const field = campos.find(f =>\n    f.field_name?.toLowerCase().includes(nombre.toLowerCase())\n  );\n  return field?.values?.[0]?.value ?? '';\n};\n\nconst telefonoCampo = camposContacto.find(f => f.field_code === 'PHONE');\nconst emailCampo    = camposContacto.find(f => f.field_code === 'EMAIL');\n\nconst now = new Date();\nconst mes = now.getMonth() + 1;\nconst ano = now.getFullYear();\n\nreturn [{ json: {\n  id_kommo:        String(contacto.id || ''),\n  nombre:          lead.name || contacto.name || '',\n  telefono:        telefonoCampo?.values?.[0]?.value || '',\n  email:           emailCampo?.values?.[0]?.value    || '',\n  valor_total:     parseFloat(leadNode.presupuesto)  || 0,\n  pais:            getField(camposLead, 'país origen'),\n  ciudad:          getField(camposLead, 'ciudad'),\n  estado_federal:  getField(camposLead, 'estado'),\n  atendente:       getField(camposLead, 'atendente'),\n  tramite:         getField(camposLead, 'trámite'),\n  nombre_pix:      getField(camposLead, 'nombre pix'),\n  policia_federal: getField(camposLead, 'policia federal'),\n  prioridad:       getField(camposLead, 'prioridad'),\n  recurrencia:     getField(camposLead, 'recorrencia') || 'NUEVO',\n  id_lead:         String(lead.id || ''),\n  pipeline_id:     String(lead.pipeline_id || ''),\n  status_id:       String(lead.status_id   || ''),\n  mes,\n  ano,\n  fecha:           now.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' + now.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }),\n}}];"
