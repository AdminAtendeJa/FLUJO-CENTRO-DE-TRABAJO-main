# URLs de servicios externos
VITE_N8N_WEBHOOK_URL=your_n8n_webhook_url_here
VITE_KOMMO_WEBHOOK_URL=your_kommo_webhook_url_here
VITE_CHATWOOT_TOKEN=your_chatwoot_token_here
